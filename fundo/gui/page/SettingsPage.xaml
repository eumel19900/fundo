<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="fundo.gui.page.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:fundo.gui.page"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local1="using:fundo.tool"
    mc:Ignorable="d"
    Loaded="SettingsPage_Loaded">

    <ScrollViewer VerticalScrollMode="Auto"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollMode="Disabled"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="20" RowSpacing="15">
            <Border
            Padding="24"
            CornerRadius="8"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">

            <StackPanel Spacing="16"
                        HorizontalAlignment="Stretch">
                <TextBlock Text="Fundo - Settings"
                       FontSize="28"
                       FontWeight="SemiBold" />

                <!-- Search index configuration section -->
                <Expander Header="Search index"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          IsExpanded="False">
                    <StackPanel Spacing="8"
                                HorizontalAlignment="Stretch">
                        <TextBlock Text="Configure indexed search and choose which drives should be included in the search index."
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <CheckBox x:Name="EnableIndexedSearchCheckBox"
                                  Content="Indexed search enabled" />

                        <TextBlock Text="Drives to include in index:"
                                   Margin="0,8,0,0"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <!-- Loading indicator shown while drives are being enumerated -->
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    Margin="0,4,0,4">
                            <ProgressRing x:Name="DriveLoadingProgressRing"
                                          IsActive="False"
                                          Visibility="Collapsed"
                                          Width="20" Height="20" />
                            <TextBlock x:Name="DriveLoadingText"
                                       Text="Loading drives..."
                                       Visibility="Collapsed"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <!-- List of drives with individual checkboxes; shows drive letter, NT path, and volume GUID -->
                        <ListView x:Name="IndexedDrivesListView"
                                  BorderThickness="1"
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                  Height="280"  
                                  IsEnabled="{Binding IsChecked, ElementName=EnableIndexedSearchCheckBox}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local1:Drive">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Center" />

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{x:Bind DriveLetter}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind NtPath}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind VolumeGuid}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" Spacing="16">
                                                <TextBlock Text="{x:Bind IndexedAtDisplay}" FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{x:Bind IndexedFileCountDisplay}" FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="" FontSize="8" TextTrimming="CharacterEllipsis" />    <!-- empty line -->
                                            </StackPanel>
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                Content="Delete index"
                                                VerticalAlignment="Center"
                                                Click="DeleteDriveIndexButton_Click"
                                                Tag="{x:Bind}"
                                                ToolTipService.ToolTip="Delete indexed files for this drive" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Button to manually start drive indexing -->
                        <Button x:Name="StartIndexingButton"
                                Click="StartIndexingButton_Click"
                                Content="Rebuild Index..."
                                Margin="0,12,0,0" />
                    </StackPanel>
                </Expander>

                <!-- Scheduled index update configuration section -->
                <Expander Header="Automatic index update"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          IsExpanded="False">
                    <StackPanel Spacing="8"
                                HorizontalAlignment="Stretch">
                        <TextBlock Text="Configure a scheduled task to refresh the search index automatically. This helps keep indexed search results up to date without starting a manual rebuild."
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <CheckBox x:Name="EnableScheduledIndexUpdateCheckBox"
                                  IsChecked="{x:Bind IsScheduledIndexUpdateEnabled, Mode=TwoWay}"
                                  Content="Enable automatic index update" />

                        <StackPanel Spacing="12"
                                    Margin="24,0,0,0"
                                    HorizontalAlignment="Stretch">
                            <TextBlock Text="Choose how often the search index should be refreshed and optionally limit execution to times when the computer is idle."
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <StackPanel Spacing="4">
                                <TextBlock Text="Update interval" />
                                <ComboBox x:Name="ScheduledIndexUpdateIntervalComboBox"
                                          ItemsSource="{x:Bind ScheduledIndexUpdateIntervals}"
                                          IsEnabled="{Binding IsChecked, ElementName=EnableScheduledIndexUpdateCheckBox}"
                                          SelectedItem="{x:Bind SelectedScheduledIndexUpdateInterval, Mode=TwoWay}"
                                          PlaceholderText="Select an interval" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Preferred execution time" />
                                <TimePicker x:Name="ScheduledIndexUpdateTimePicker"
                                            IsEnabled="{Binding IsChecked, ElementName=EnableScheduledIndexUpdateCheckBox}"
                                            SelectedTime="{x:Bind ScheduledIndexUpdatePreferredTime, Mode=TwoWay}"
                                            ClockIdentifier="24HourClock"
                                            MinuteIncrement="15" />
                            </StackPanel>

                            <CheckBox x:Name="RunScheduledIndexUpdateOnlyWhenIdleCheckBox"
                                      IsEnabled="{Binding IsChecked, ElementName=EnableScheduledIndexUpdateCheckBox}"
                                      IsChecked="{x:Bind RunScheduledIndexUpdateOnlyWhenIdle, Mode=TwoWay}"
                                      Content="Only run automatic updates when the computer is idle" />
                        </StackPanel>
                    </StackPanel>
                </Expander>

                <!-- Global shortcut configuration section -->
                <Expander Header="Global shortcut"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          IsExpanded="False">
                    <StackPanel Spacing="8"
                                HorizontalAlignment="Stretch">
                        <TextBlock Text="A global shortcut lets you open the Fundo main window from any application using a keyboard shortcut. The shortcut works system-wide, even when Fundo is minimized or running in the background."
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <TextBlock Text="To configure the shortcut, enable it below and click 'Record shortcut'. Then press the desired key combination (for example Ctrl+F3 or Win+F3). Modifier keys such as Ctrl, Alt, Shift and Win can be combined with a regular key."
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <CheckBox x:Name="EnableGlobalHotkeyCheckBox"
                                  IsChecked="{x:Bind IsGlobalHotkeyEnabled, Mode=TwoWay}"
                                  Content="Enable global shortcut" />

                        <StackPanel Spacing="4"
                                    Margin="24,0,0,0">
                            <TextBlock Text="Shortcut" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="HotkeyTextBox"
                                         IsReadOnly="True"
                                         Text="{x:Bind GlobalHotkeyKeys, Mode=OneTime}"
                                         IsEnabled="{Binding IsChecked, ElementName=EnableGlobalHotkeyCheckBox}"
                                         Width="200"
                                         PlaceholderText="No shortcut set" />
                                <Button x:Name="RecordHotkeyButton"
                                        Content="Record shortcut"
                                        IsEnabled="{Binding IsChecked, ElementName=EnableGlobalHotkeyCheckBox}"
                                        Click="RecordHotkeyButton_Click"
                                        KeyDown="RecordHotkeyButton_KeyDown"
                                        LostFocus="RecordHotkeyButton_LostFocus" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Expander>

                <!-- Autostart configuration section -->
                <Expander Header="Autostart"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          IsExpanded="False">
                    <StackPanel Spacing="8"
                                HorizontalAlignment="Stretch">
                        <TextBlock Text="When autostart is enabled, Fundo launches automatically when you sign in to Windows. The application starts minimized to the notification area so it is ready for use without interrupting your workflow."
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <TextBlock Text="You can open Fundo at any time by clicking its icon in the notification area or by pressing the global shortcut (if configured)."
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <CheckBox x:Name="EnableAutostartCheckBox"
                                  IsChecked="{x:Bind IsAutostartEnabled, Mode=TwoWay}"
                                  Content="Launch Fundo automatically when you sign in" />
                    </StackPanel>
                </Expander>
            </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>

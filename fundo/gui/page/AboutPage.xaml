<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="fundo.gui.page.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:fundo.gui.page"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="15">
        <Border
            Padding="24"
            CornerRadius="8"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">

            <StackPanel Spacing="12">
                <!-- App name and short description -->
                <TextBlock Text="Fundo v1.0"
                           FontSize="28"
                           FontWeight="SemiBold" />

                <TextBlock Text="Fundo searches your files whether you want it or not."
                           TextWrapping="WrapWholeWords"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <Rectangle Height="1"
                           Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                           Margin="0,8,0,0" />

                <!-- Author information -->
                <StackPanel Orientation="Vertical" Spacing="4">
                    <TextBlock Text="Made in 2026"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Robert Wermuth" />
                    <TextBlock Text="fundo.search@gmail.com"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                               IsTextSelectionEnabled="True" />
                </StackPanel>

                <Rectangle Height="1"
                           Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                           Margin="0,8,0,0" />

                <StackPanel Orientation="Vertical" Spacing="8">
                    <TextBlock Text="License"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Fundo is published under the Beerware License: &quot;As long as you retain this notice you can do whatever you want with this stuff. If we meet some day, and you think this stuff is worth it, you can buy me a beer in return.&quot;"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Text="If you enjoy Fundo, feel invited to buy me a beer someday. Feel free to send your questions, suggestions, and bug reports by email to fundo.search@gmail.com."
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>

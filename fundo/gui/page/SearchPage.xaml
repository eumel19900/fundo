<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="fundo.gui.page.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:fundo.gui.page"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:src="using:fundo.gui.control"
    xmlns:model="using:fundo.core.Search"
    mc:Ignorable="d">

    <Grid>
        <!-- Inhaltsebene -->
        <Grid Padding="20" RowSpacing="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- filename -->
            <StackPanel Spacing="5">
                <TextBlock Text="Filename" FontWeight="SemiBold"/>
                <TextBox x:Name="SearchPatternTextBox"
                         PlaceholderText="*.jpeg"/>
            </StackPanel>

            <!-- search location -->
            <StackPanel Grid.Row="1" Spacing="5" Orientation="Vertical">
                <TextBlock Text="SearchLocation" FontWeight="SemiBold"/>
                <Grid ColumnSpacing="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <src:LocationControl Grid.Column="0"
                                         x:Name="LocationControl"
                                         SelectedDirectoryChanged="LocationControl_SelectedDirectoryChanged"/>
                </Grid>
            </StackPanel>

            <!-- filter tabs -->
            <NavigationView Grid.Row="2"
                            x:Name="FilterNavigationView"
                            PaneDisplayMode="Top"
                            IsSettingsVisible="False"
                            IsBackButtonVisible="Collapsed"
                            SelectionChanged="FilterNavigationView_SelectionChanged">
                <NavigationView.MenuItems>
                    <NavigationViewItem x:Name="DateFilterNav" Content="Filter by date" Tag="date" Icon="Calendar" IsSelected="True" />
                    <NavigationViewItem x:Name="FilesizeFilterNav" Content="Filter by filesize" Tag="size" Icon="Page"/>
                    <NavigationViewItem x:Name="FileAttributesFilterNav" Content="Filter by file attributes" Tag="attributes" Icon="Tag"/>
                    <NavigationViewItem x:Name="FilterContentFilterNav" Content="Filter by file content" Tag="content" Icon="Document"/>
                </NavigationView.MenuItems>

                <Frame x:Name="ContentFrame"/>
            </NavigationView>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="SearchInfoTextBlock"
                           VerticalAlignment="Center"/>
                <Button x:Name="SearchButton"
                        Click="SearchButton_Clicked"
                        Content="Start search"
                        HorizontalAlignment="Right"
                        Padding="20,8"/>
            </Grid>

            <Border Grid.Row="4"
                    Padding="20,8"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <ListView x:Name="SearchResultListView"
                          SelectionMode="Single"
                          RightTapped="SearchResultListView_RightTapped"
                          DoubleTapped="SearchResultListView_DoubleTapped">
                    <ListView.ContextFlyout>
                        <MenuFlyout Opening="SearchResultMenuFlyout_Opening">
                            <MenuFlyoutItem x:Name="OpenFileMenuFlyoutItem"
                                            Text="Open File..."
                                            IsEnabled="False"
                                            Click="OpenFileMenuFlyoutItem_Click">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="OpenFile" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Name="LocateFileMenuFlyoutItem"
                                            Text="Locate File..."
                                            IsEnabled="False"
                                            Click="LocateFileMenuFlyoutItem_Click">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="OpenLocal" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Name="CopyFileMenuFlyoutItem"
                                            Text="Copy"
                                            IsEnabled="False"
                                            Click="CopyFileMenuFlyoutItem_Click">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="Copy" />
                                </MenuFlyoutItem.Icon>
                                <MenuFlyoutItem.KeyboardAccelerators>
                                    <KeyboardAccelerator Modifiers="Control" Key="C" />
                                </MenuFlyoutItem.KeyboardAccelerators>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </ListView.ContextFlyout>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="model:SearchResultItem">
                            <StackPanel Orientation="Horizontal" Margin="4" VerticalAlignment="Center">
                                <Image Source="{x:Bind FileImage, Mode=OneWay}"
                                       Width="32" Height="32" Margin="0,0,8,0"/>

                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="{x:Bind FileName}"
                                               FontSize="18"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="{x:Bind Path}"
                                               FontSize="10"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind FileDate}"
                                               FontSize="10"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind FileSizeString}"
                                               FontSize="10"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>

        <!-- Überlagernder InfoBar, hoher Z-Index -->
        <InfoBar x:Name="SearchEngineInfoBar"
                 Canvas.ZIndex="100"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Top"
                 Margin="20,20,20,0"
                 IsOpen="False"
                 Severity="Informational"
                 Title="Search engine"
                 Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                 BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                 BorderThickness="1"
                 Padding="12">
        </InfoBar>
    </Grid>
</Page>

<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="fundo.gui.control.LocationPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:fundo.gui.control"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Select Directories"
    PrimaryButtonText="OK"
    SecondaryButtonText="Cancel"
    DefaultButton="Primary"
    FullSizeDesired="False"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    SecondaryButtonClick="ContentDialog_SecondaryButtonClick">

    <Grid MinWidth="500" MinHeight="400" MaxWidth="800" MaxHeight="600" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with description -->
        <TextBlock Grid.Row="0"
                   Text="Manage the list of directories to search in."
                   TextWrapping="Wrap"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

        <!-- Directory list -->
        <Border Grid.Row="1"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="4">
            <ListView x:Name="DirectoryListView"
                      SelectionMode="Single"
                      SelectionChanged="DirectoryListView_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Grid Padding="8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE8B7;" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <!-- Action buttons sized to fill available width -->
        <Grid Grid.Row="2" MinHeight="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button x:Name="AddButton"
                    Grid.Column="0"
                    ToolTipService.ToolTip="Add directory"
                    Click="AddButton_Click"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                    <TextBlock Text="Add"/>
                </StackPanel>
            </Button>

            <Button x:Name="EditButton"
                    Grid.Column="1"
                    ToolTipService.ToolTip="Change selected directory"
                    IsEnabled="False"
                    Click="EditButton_Click"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                    <TextBlock Text="Edit"/>
                </StackPanel>
            </Button>

            <Button x:Name="RemoveButton"
                    Grid.Column="2"
                    ToolTipService.ToolTip="Remove selected directory"
                    IsEnabled="False"
                    Click="RemoveButton_Click"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                    <TextBlock Text="Remove"/>
                </StackPanel>
            </Button>

            <Button x:Name="AllDrivesButton"
                    Grid.Column="3"
                    ToolTipService.ToolTip="Replace list with all available drives"
                    Click="AllDrivesButton_Click"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xEDA2;" FontSize="14"/>
                    <TextBlock Text="All Drives"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</ContentDialog>
